---
import { SITE_TITLE, NAV_LINKS } from '../consts';

// Normalize the current path so nav highlighting works with/without a base path.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const current = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container container-wide">
    <a class="brand" href={`${base}/`}>{SITE_TITLE}</a>
    <nav class="nav" aria-label="Primary">
      {
        NAV_LINKS.map((link) => {
          const target = link.href.replace(/\/$/, '') || '/';
          const isActive = target === current;
          return (
            <a
              href={`${base}${link.href}`}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
