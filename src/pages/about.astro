---
import Base from '../layouts/Base.astro';
---

<Base title="About" description="A little about me.">
  <h1>About</h1>
  <p>
    Hi — I'm <strong>Your Name</strong>. This is where you introduce yourself:
    what you do, what you care about, and what you like to write about.
  </p>
  <p>
    You can edit this page in <code>src/pages/about.astro</code>. Write as much
    or as little as you like. A few paragraphs is plenty.
  </p>
  <p>
    Want to get in touch? Update the links in <code>src/consts.ts</code> and
    they'll appear in the footer of every page.
  </p>
</Base>
