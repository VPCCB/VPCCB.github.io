---
import Base from '../layouts/Base.astro';

// Edit this list to showcase your projects.
const projects = [
  {
    title: 'Project One',
    description: 'A short description of what this is and why it matters.',
    href: 'https://github.com/your-username/project-one',
    tags: ['Web', 'TypeScript'],
  },
  {
    title: 'Project Two',
    description: 'Something you built, wrote, or designed. Link it anywhere.',
    href: 'https://github.com/your-username/project-two',
    tags: ['Design', 'Side project'],
  },
  {
    title: 'Project Three',
    description: 'Replace these cards with your real work.',
    href: '#',
    tags: ['Experiment'],
  },
];
---

<Base title="Work" description="Selected projects and things I've made.">
  <h1>Work</h1>
  <p>A selection of things I've built and made. Edit these in <code>src/pages/work.astro</code>.</p>

  <div class="work-grid">
    {
      projects.map((project) => (
        <a class="work-card" href={project.href} target="_blank" rel="noopener" style="text-decoration:none;display:block">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </a>
      ))
    }
  </div>
</Base>
